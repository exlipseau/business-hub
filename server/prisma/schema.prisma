generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id        String   @id @default(cuid())
  name      String
  colour    String
  type      String
  createdAt DateTime @default(now())

  projects      Project[]
  tasks         Task[]
  leads         Lead[]
  timeEntries   TimeEntry[]
  goals         Goal[]
  calendarEvents CalendarEvent[]
  contacts      ContactBusiness[]
}

model Project {
  id          String    @id @default(cuid())
  businessId  String
  clientName  String
  stage       String    @default("Discovery")
  deadline    DateTime?
  hoursLogged Float     @default(0)
  revenue     Float     @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business    Business  @relation(fields: [businessId], references: [id])
  timeEntries TimeEntry[]
  tasks       Task[]
}

model Task {
  id         String    @id @default(cuid())
  businessId String
  projectId  String?
  title      String
  category   String    @default("Admin")
  priority   String    @default("medium")
  stage      String?
  dueDate    DateTime?
  startTime  DateTime?
  duration   Int?
  completed  Boolean   @default(false)
  recurring  String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business   Business  @relation(fields: [businessId], references: [id])
  project    Project?  @relation(fields: [projectId], references: [id])
}

model Lead {
  id            String    @id @default(cuid())
  businessId    String
  name          String
  company       String?
  value         Float?
  source        String    @default("Website")
  stage         String    @default("New")
  lastContact   DateTime?
  nextFollowUp  DateTime?
  notes         String?
  wonLostReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business      Business  @relation(fields: [businessId], references: [id])
  contact       Contact?  @relation(fields: [contactId], references: [id])
  contactId     String?
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  company   String?
  email     String?
  phone     String?
  status    String   @default("Prospect")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interactions ContactBusiness[]
  logs         Interaction[]
  leads        Lead[]
}

model ContactBusiness {
  id         String  @id @default(cuid())
  contactId  String
  businessId String

  contact    Contact  @relation(fields: [contactId], references: [id])
  business   Business @relation(fields: [businessId], references: [id])

  @@unique([contactId, businessId])
}

model Interaction {
  id        String   @id @default(cuid())
  contactId String
  type      String
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  contact   Contact  @relation(fields: [contactId], references: [id])
}

model TimeEntry {
  id         String    @id @default(cuid())
  businessId String
  projectId  String?
  category   String    @default("Client Work")
  startTime  DateTime
  endTime    DateTime?
  duration   Int?
  notes      String?
  createdAt  DateTime  @default(now())

  business   Business  @relation(fields: [businessId], references: [id])
  project    Project?  @relation(fields: [projectId], references: [id])
}

model Goal {
  id         String   @id @default(cuid())
  businessId String?
  type       String
  name       String
  target     Float
  current    Float    @default(0)
  period     String   @default("monthly")
  unit       String   @default("GBP")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business   Business? @relation(fields: [businessId], references: [id])
}

model CalendarEvent {
  id         String    @id @default(cuid())
  businessId String?
  title      String
  category   String    @default("Admin")
  start      DateTime
  end        DateTime
  allDay     Boolean   @default(false)
  recurring  String?
  notes      String?
  isDeadline Boolean   @default(false)
  taskId     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business   Business? @relation(fields: [businessId], references: [id])
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
